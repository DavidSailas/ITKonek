{
  "expo": {
    "name": "ITKonek",
    "slug": "itkonek",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/logo/logo.png",
    "scheme": "itkonek",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.anonymous.itkonek",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_MEDIA_LOCATION",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "config": {
        "firebase": {
          "apiKey": "AIzaSyCX9xz8QYnFNEbwK45hdKBoP7_zvbdKQ34",
          "authDomain": "jms-one-it.firebaseapp.com",
          "projectId": "jms-one-it",
          "storageBucket": "jms-one-it.firebasestorage.app",
          "messagingSenderId": "923030827484",
          "appId": "1:923030827484:web:bea5e4978abdbdbe309f19",
          "measurementId": "G-XF7F1X6Y21"
        }
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff"
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow ITKonek to access your photos",
          "savePhotosPermission": "Allow ITKonek to save photos",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "7d3f6a66-b954-445b-9675-21c49600ecce"
      }
    }
  }
}